# Copy this file to .env before running docker compose.
# Do not commit .env because it contains real credentials.

MODEL_API_KEY=your-dashscope-api-key
EMBEDDING_API_KEY=your-siliconflow-api-key

OMNIQUERY_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OMNIQUERY_LLM_MODEL=kimi-k2.6

OMNIQUERY_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/embeddings
OMNIQUERY_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=omniquery_demo
MYSQL_PORT=3307

POSTGRES_PASSWORD=root
POSTGRES_PORT=5433
OMNIQUERY_VECTOR_DIMENSIONS=1024
